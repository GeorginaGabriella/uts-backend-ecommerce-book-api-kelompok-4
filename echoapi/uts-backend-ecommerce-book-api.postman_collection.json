  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const defaults = {",
          "  baseUrl: 'http://localhost:5000',",
          "  username: 'felicia',",
          "  reviewUsername: 'felicia',",
          "  userEmail: 'felicia@example.com',",
          "  userPassword: 'secret123',",
          "  newPassword: 'secret456',",
          "  userPhone: '081234567890',",
          "  addressIndex: '0',",
          "  productId: '',",
          "  bookId: '',",
          "  cartProductId: '',",
          "  orderId: '',",
          "  orderNumber: '',",
          "  adminToken: '',",
          "  paymentMethod: 'BANK_TRANSFER'",
          "};",
          "",
          "Object.entries(defaults).forEach(([key, value]) => {",
          "  if (pm.collectionVariables.get(key) === undefined) {",
          "    pm.collectionVariables.set(key, value);",
          "  }",
          "});",
          "",
          "const token = pm.collectionVariables.get('token');",
          "if (token && (!pm.request.auth || pm.request.auth.type !== 'noauth')) {",
          "  pm.request.headers.upsert({",
          "    key: 'Authorization',",
          "    value: `Bearer ${token}`",
          "  });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response is not a server error', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});",
          "",
          "let json = null;",
          "try {",
          "  json = pm.response.json();",
          "} catch (error) {",
          "  json = null;",
          "}",
          "",
          "const setVar = (key, value) => {",
          "  if (value !== undefined && value !== null && value !== '') {",
          "    pm.collectionVariables.set(key, String(value));",
          "  }",
          "};",
          "",
          "if (!json) {",
          "  return;",
          "}",
          "",
          "const requestUrl = pm.request.url.toString();",
          "const requestName = (pm.info.requestName || '').toLowerCase();",
          "const payload = json.data !== undefined ? json.data : json;",
          "const arrayPayload = Array.isArray(payload)",
          "  ? payload",
          "  : Array.isArray(json)",
          "    ? json",
          "    : null;",
          "",
          "if (json.token) {",
          "  setVar('token', json.token);",
          "}",
          "",
          "if ((requestUrl.includes('/api/auth') || requestUrl.includes('/api/users')) && payload && typeof payload === 'object' && !Array.isArray(payload)) {",
          "  setVar('userId', payload.id || payload._id);",
          "  setVar('username', payload.username);",
          "  setVar('reviewUsername', payload.username);",
          "  setVar('userEmail', payload.email);",
          "}",
          "",
          "if (requestUrl.includes('/api/products')) {",
          "  const product = Array.isArray(arrayPayload) ? arrayPayload.find(item => item && item._id) : payload;",
          "  if (product && product._id) {",
          "    setVar('productId', product._id);",
          "    setVar('bookId', product._id);",
          "    setVar('cartProductId', product._id);",
          "  }",
          "}",
          "",
          "if (requestUrl.includes('/api/cart') && payload && Array.isArray(payload.items) && payload.items.length > 0) {",
          "  const firstItem = payload.items[0];",
          "  const productId = firstItem.productId && typeof firstItem.productId === 'object'",
          "    ? firstItem.productId._id",
          "    : firstItem.productId;",
          "  setVar('cartProductId', productId);",
          "}",
          "",
          "if (requestUrl.includes('/api/orders')) {",
          "  const order = Array.isArray(arrayPayload) ? arrayPayload.find(item => item && item._id) : payload;",
          "  if (json.orderId) {",
          "    setVar('orderNumber', json.orderId);",
          "  }",
          "  if (order && order._id) {",
          "    setVar('orderId', order._id);",
          "  }",
          "  if (order && order.orderNumber) {",
          "    setVar('orderNumber', order.orderNumber);",
          "  }",
          "}",
          "",
          "if (requestUrl.includes('/api/payments') && payload && typeof payload === 'object' && !Array.isArray(payload)) {",
          "  setVar('orderId', payload.orderId || payload._id);",
          "}",
          "",
          "if (requestUrl.includes('/api/users/address') && Array.isArray(payload) && payload.length > 0) {",
          "  setVar('addressIndex', '0');",
          "}",
          "",
          "if (requestName === 'change password' && pm.response.code < 400) {",
          "  const nextPassword = pm.collectionVariables.get('newPassword');",
          "  if (nextPassword) {",
          "    pm.collectionVariables.set('userPassword', nextPassword);",
          "  }",
          "}",
          "",
          "if (requestName === 'logout' && pm.response.code < 400) {",
          "  pm.collectionVariables.unset('token');",
          "}"
        ]
      }
    }
  ],
