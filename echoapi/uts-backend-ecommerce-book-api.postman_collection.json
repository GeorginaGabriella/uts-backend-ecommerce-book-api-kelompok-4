                  "if (data.token) {",
                  "  pm.collectionVariables.set('token', data.token);",
                  "}",
                  "if (data.data) {",
                  "  if (data.data.id) {",
                  "    pm.collectionVariables.set('userId', data.data.id);",
                  "  }",
                  "  if (data.data.username) {",
                  "    pm.collectionVariables.set('username', data.data.username);",
                  "    pm.collectionVariables.set('reviewUsername', data.data.username);",
                  "  }",
                  "  if (data.data.email) {",
                  "    pm.collectionVariables.set('userEmail', data.data.email);",
                  "  }",
                  "}"
                ]
              }
            }
